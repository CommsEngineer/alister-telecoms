---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />

		<main>
			<h1>Peak Rock Communication Services</h1>

			<p>
				My name is Alister, and I am a vanlifer, with 15 years of experience in the telecommunications and networking world. Due to my lifestyle, I am uniquely placed to reach all areas of the UK and Europe  to assist my customers with overhauling and renewing their network infrastructure. <br />
				I provide new installation and refurbishment of internet networks.
			</p>

			<section id="services" class="offerings">
				<div class="section-header">
					<h2>What I Do</h2>
					<button id="detailToggle" class="detail-toggle" type="button">Detailed mode</button>
		</div>
	</nav>
</header>

<style>
	header {
		padding: 1rem 1.5rem;
		border-bottom: 1px solid #ddd;
		background: white;
	}

	nav {
		display: flex;
		justify-content: space-between;
		align-items: center;
		gap: 1rem;
		flex-wrap: wrap;
	}

	.logo img {
		height: 60px;
		width: auto;
		display: block;
		max-width: 100%;
	}

	.nav-links {
		display: flex;
		gap: 1rem;
		flex-wrap: wrap;
		justify-content: flex-end;
	}

	.nav-links a {
		text-decoration: none;
		color: black;
		padding: 0.8rem 1.2rem;
		border: 1px solid #ccc;
		border-radius: 8px;
		font-family: Arial, sans-serif;
		font-size: 1rem;
		line-height: 1.2;
		white-space: nowrap;
	}

	@media (max-width: 900px) {
		nav {
			flex-direction: column;
			align-items: center;
		}

		.nav-links {
			justify-content: center;
		}
	}

	@media (max-width: 600px) {
		header {
			padding: 0.8rem 1rem;
		}

		.logo img {
			height: 48px;
		}

		.nav-links {
			width: 100%;
			justify-content: center;
			gap: 0.75rem;
		}

		.nav-links a {
			padding: 0.7rem 1rem;
			font-size: 0.95rem;
		}
	}
</style>